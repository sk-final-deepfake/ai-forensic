AI_SERVER_NAME=forenshield-ai
AI_SERVER_PORT=8000
BACKEND_RESULT_API_URL=http://localhost:8080/api/analysis/results

# --- RabbitMQ (AI worker, Option A) ---
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
ANALYSIS_EXCHANGE=ai.analysis.exchange
AI_RESULT_EXCHANGE=ai.result.exchange
ANALYSIS_DLX=ai.dead.exchange
ANALYSIS_QUEUE=forenshield.analysis.queue
AI_RESULT_QUEUE=backend.ai.result.queue
ANALYSIS_DLQ=forenshield.analysis.dlq
ANALYSIS_ROUTING_KEY=analyze.video
AI_RESULT_ROUTING_KEY=result.video
RABBITMQ_PREFETCH=1

# Set 1 for queue smoke test without GPU weights
USE_MOCK_INFER=0

# Model paths (relative to ai/ root unless absolute)
XCEPTION_WEIGHTS=models/test/video/xception/v1.0.0/xception_best.pth
TIMESFORMER_WEIGHTS=models/test/video/timesformer/v1.0.0/timesformer_finetuned.pth
FUSION_CONFIG_PATH=config/fusion_v0.json
OPTICAL_COHORT_PATH=config/optical_flow_cohort_v0.json
INFER_DEVICE=cuda
